# Frontend (Vercel) – javni vrednosti, gresta v config.js
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...

# Uporablja se SAMO v mock (lokalnem) načinu. V produkciji dashboard
