# Uporablja ga Supabase Database Webhook (ne frontend).
N8N_WEBHOOK_URL=https://tvoj-n8n.domena.com/webhook/review-alert

# Opomba: SERVICE/secret ključ NI več potreben v frontendu (dashboard
